<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Modern Shop</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <header class="container header">
    <a href="/" class="logo">SHOP</a>
    <nav class="nav">
      <a href="#catalog">Каталог</a>
      <button id="cart-btn">🛒 <span id="cart-count">0</span></button>
    </nav>
  </header>

  <main class="container">
    <section id="hero" class="hero">
      <h1>Современный магазин</h1>
      <p>Простота. Качество. Скорость.</p>
    </section>
    <section id="catalog" class="catalog">
      <h2>Каталог</h2>
      <div id="products" class="products-grid"></div>
    </section>
  </main>

  <div id="cart-modal" class="modal hidden">
    <div class="modal-content">
      <button id="close-cart" class="close">×</button>
      <h3>Корзина</h3>
      <ul id="cart-items"></ul>
      <div class="cart-total">Итого: <span id="total-price">0</span> ₽</div>
      <button id="checkout-btn" class="btn primary">Оформить</button>
    </div>
  </div>

  <footer class="container footer">© 2026 Modern Shop</footer>
  <script src="js/main.js"></script>
</body>
</html>
